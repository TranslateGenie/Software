{
  "name": "mdas-electron",
  "version": "1.1.2",
  "type": "module",
  "description": "Multilingual Document Automation System — Electron App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently --kill-others-on-fail \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder --publish never"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "dotenv": "^16.4.5",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "keytar": "^7.9.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.4",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.translategenie.app",
    "productName": "Translate Genie",
    "artifactName": "TranslateGenie-Setup.${ext}",
    "icon": "Logo.png",
    "directories": {
      "output": "dist"
    },
    "win": {
      "azureSignOptions": {
        "publisherName": "Kayleb Pettinger",
        "endpoint": "https://eus.codesigning.azure.net/",
        "codeSigningAccountName": "translate-genie",
        "certificateProfileName": "translate-genie"
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/dist/**",
      "assets/fonts/**",
      "node_modules/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "TranslateGenie",
      "repo": "Software"
    },
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules/**"
        ]
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*",
          "!.cache/**"
        ]
      }
    ]
  }
}
