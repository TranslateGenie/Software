{
  "name": "mdas-electron",
  "version": "1.0.0",
  "description": "Multilingual Document Automation System — Electron App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build && electron-builder"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.4"
  },
  "build": {
    "appId": "com.mdas.app",
    "productName": "MDAS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/dist/**",
      "node_modules/**"
    ]
  }
}
